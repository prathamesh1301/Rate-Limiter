{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/rate-limit": {
            "get": {
                "description": "Checks if a user has exceeded their rate limit using the token bucket algorithm.\nReads from Redis first, falls back to PostgreSQL on cache miss.\nNew users are automatically created with full tokens.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "rate-limiter"
                ],
                "summary": "Check rate limit for a user",
                "parameters": [
                    {
                        "type": "string",
                        "description": "User ID to rate limit",
                        "name": "user_id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Request allowed",
                        "schema": {
                            "$ref": "#/definitions/main.ResultDetail"
                        },
                        "headers": {
                            "X-Data-Source": {
                                "type": "string",
                                "description": "Data source: redis | postgres | new-user -\u003e postgres"
                            }
                        }
                    },
                    "400": {
                        "description": "user_id is required",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "429": {
                        "description": "Rate limit exceeded",
                        "schema": {
                            "$ref": "#/definitions/main.ResultDetail"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "main.ResultDetail": {
            "type": "object",
            "properties": {
                "allowed": {
                    "type": "boolean"
                },
                "refresh_after": {
                    "description": "seconds until next token",
                    "type": "integer"
                }
            }
        }
    }
}